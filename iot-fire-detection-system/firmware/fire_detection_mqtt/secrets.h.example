// انسخ هذا الملف إلى secrets.h واملأ بياناتك الحقيقية.
// ملف secrets.h مستثنى من Git — لا ترفع بياناتك الحقيقية أبداً!
//
// Copy this file to secrets.h and fill in your real credentials.
// secrets.h is git-ignored — never commit real credentials!

#ifndef SECRETS_H
#define SECRETS_H

// Wi-Fi credentials
#define WIFI_SSID       "YOUR_WIFI_NAME"
#define WIFI_PASSWORD   "YOUR_WIFI_PASSWORD"

// MQTT broker
// - Local broker (recommended for a safety system): IP of the machine
//   running Mosquitto on your network, e.g. "192.168.1.10"
// - Or a public/cloud broker for testing, e.g. "broker.hivemq.com"
#define MQTT_BROKER     "192.168.1.10"
#define MQTT_PORT       1883

// Leave both empty ("") if your broker allows anonymous access
#define MQTT_USER       ""
#define MQTT_PASS       ""

#endif // SECRETS_H
